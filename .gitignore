# Dark Web Leak Monitor - Git Ignore File

# ==================== Environment & Secrets ====================
# NEVER commit these files - they contain sensitive data
.env
.env.local
.env.production
*.env
secrets.py
config.local.py
# Add sensitive files and folders
*.json
instance/

# ==================== Python ====================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
.venv/
venv/
ENV/
env/
.virtualenv/

# ==================== IDE / Editor ====================
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# ==================== OS Files ====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ==================== Project Specific ====================
# Exports folder contents (keep folder, ignore contents)
exports/*.html
exports/*.pdf
exports/*.json
!exports/.gitkeep

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.tmp/
temp/

# Database files
*.db
*.sqlite
*.sqlite3

# Uploaded files
uploads/
